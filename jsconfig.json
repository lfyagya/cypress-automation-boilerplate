{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@configs/*": ["cypress/configs/*"],
      "@support/*": ["cypress/support/*"],
      "@fixtures/*": ["cypress/fixtures/*"],
      "@tests/*": ["cypress/tests/*"],
      "@schemas/*": ["cypress/schemas/*"],
      "@core/*": ["cypress/support/core/*"]
    },
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "types": ["cypress", "node"]
  },
  "include": ["cypress/**/*.js", "cypress.config.js"],
  "exclude": [
    "node_modules",
    "cypress/videos",
    "cypress/screenshots",
    "cypress/downloads",
    "reports"
  ]
}

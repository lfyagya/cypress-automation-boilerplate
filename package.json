{
  "name": "cypress-command-first-boilerplate",
  "version": "1.0.0",
  "description": "Cypress automation boilerplate — Config → Custom Commands → Tests. No page objects. No action files.",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:smoke": "cypress run --spec 'cypress/tests/**/smoke/**/*.cy.js'",
    "cy:run:e2e": "cypress run --spec 'cypress/tests/**/e2e/**/*.cy.js'",
    "cy:run:module": "cypress run --spec \"cypress/tests/${MODULE}/**/*.cy.js\"",
    "cy:run:tag": "cypress run --env grepTags=${TAG}",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:all": "npm run lint && npm run format:check"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@cypress/grep": "^4.1.0",
    "@cypress/webpack-preprocessor": "^6.0.2",
    "@eslint/js": "^9.15.0",
    "@faker-js/faker": "^9.3.0",
    "@testing-library/cypress": "^10.0.3",
    "babel-loader": "^9.2.1",
    "cypress": "^13.16.0",
    "cypress-mochawesome-reporter": "^3.8.2",
    "cypress-real-events": "^1.13.0",
    "cypress-wait-until": "^2.0.1",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-cypress": "^3.6.0",
    "prettier": "^3.3.3"
  },
  "author": "",
  "license": "ISC"
}
